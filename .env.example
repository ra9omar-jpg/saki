# === ANTHROPIC (Claude AI) ===
ANTHROPIC_API_KEY=sk-ant-...

# === META WHATSAPP BUSINESS CLOUD API ===
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxx
WHATSAPP_VERIFY_TOKEN=valgfri-hemmelig-streng
WHATSAPP_APP_SECRET=xxxx
WHATSAPP_PHONE_NUMBER=+4555228034

# === WHATSAPP GRUPPE-IDS ===
# Fås efter Saki er tilføjet til grupperne og der modtages en besked
WHATSAPP_GROUP_MARKETING=xxxx
WHATSAPP_GROUP_RD=xxxx
WHATSAPP_GROUP_EXPERTISE_REVIEW=xxxx
WHATSAPP_GROUP_TEACHERS=xxxx
WHATSAPP_GROUP_COMMUNITY=xxxx

# === MICROSOFT AZURE (Graph API) ===
AZURE_TENANT_ID=xxxx
AZURE_CLIENT_ID=xxxx
AZURE_CLIENT_SECRET=xxxx

# === MICROSOFT TEAMS KANAL-IDS ===
TEAMS_GROUP_ID=xxxx
TEAMS_CHANNEL_MARKETING=xxxx
TEAMS_CHANNEL_RD=xxxx
TEAMS_CHANNEL_EXPERTISE_REVIEW=xxxx
TEAMS_CHANNEL_TEACHERS=xxxx

# === MICROSOFT PLANNER ===
PLANNER_PLAN_ID_RD=xxxx
PLANNER_PLAN_ID_MARKETING=xxxx
PLANNER_BUCKET_TODO=xxxx
PLANNER_BUCKET_IN_PROGRESS=xxxx
PLANNER_BUCKET_READY_FOR_REVIEW=xxxx
PLANNER_BUCKET_APPROVED=xxxx
PLANNER_BUCKET_DONE=xxxx

# === RANI (administrator) ===
RANI_WHATSAPP=4512345678
RANI_TEAMS_USER_ID=xxxx
RANI_NAME=Rani

# === TELEGRAM BOT API ===
# Opret en bot via @BotFather på Telegram. Du får en token som:
# 1234567890:ABCdefGHIjklMNOpqrSTUVwxyz
TELEGRAM_BOT_TOKEN=

# Hemmeligt suffiks til webhook-URL — vælg en lang tilfældig streng
# Telegram kalder: POST https://yourapp.railway.app/webhook/telegram/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=

# === TELEGRAM GRUPPE-IDS ===
# Tilføj Saki-botten som ADMIN i gruppen og send /start — gruppe-ID ses i Railway logs
# Grupper bruger negative tal, f.eks. -1001234567890
TELEGRAM_GROUP_MARKETING=
TELEGRAM_GROUP_RD=
TELEGRAM_GROUP_EXPERTISE_REVIEW=
TELEGRAM_GROUP_TEACHERS=
TELEGRAM_GROUP_COMMUNITY=

# Ranis personlige Telegram bruger-ID (positivt tal)
# Find det ved at sende en besked til @userinfobot på Telegram
RANI_TELEGRAM_ID=

# === TEST TELEGRAM-GRUPPER ===
TEST_TELEGRAM_GROUP_RD=
TEST_TELEGRAM_GROUP_MARKETING=
TEST_TELEGRAM_GROUP_TEACHERS=
TEST_TELEGRAM_GROUP_EXPERTISE=

# === SAKI TILSTAND ===
# Start altid i test. Skift til shadow/live via kontrol-menu.
SAKI_MODE=test

# === TESTGRUPPER (opret i Ranis personlige WhatsApp) ===
# IDs fås ved at tilføje Saki til gruppen og modtage en besked
TEST_WHATSAPP_GROUP_RD=xxxx          # "Saki Test – R&D"
TEST_WHATSAPP_GROUP_MARKETING=xxxx   # "Saki Test – Marketing"
TEST_WHATSAPP_GROUP_TEACHERS=xxxx    # "Saki Test – Lærere"
TEST_WHATSAPP_GROUP_EXPERTISE=xxxx   # "Saki Test – Ekspertise"
TEST_PLANNER_ID=xxxx                 # "Saki Test Plan" i Microsoft Planner

# === SAKI KONTROL ===
SAKI_SECRET_CODE=vælg-en-hemmelig-sætning   # Kun Rani kender denne
SAKI_QUICK_PAUSE_TRIGGER=Saki!!!

# === SPØRGSMÅL-ESKALERING ===
QUESTION_REMINDER_DELAY_HOURS=4
QUESTION_ABANDONED_NOTIFY_DELAY_HOURS=24

# === TO-DO GENERATOR ===
TODO_LOOKBACK_HOURS=2

# === MØNSTER-ESKALERING ===
MISS_FIRST_FLAG=1
MISS_SECOND_NOTIFY=2
MISS_THIRD_ALERT=3

# === AUDIO TRANSSKRIPTION (valgfri) ===
# Kræves kun til workshop-optagelser (Function 12)
WHISPER_API_KEY=sk-...    # OpenAI API-nøgle

# === APP ===
SECRET_KEY=skift-dette-til-en-lang-tilfaeldig-streng
DATABASE_URL=sqlite:///saki.db   # Skift til PostgreSQL URL på Railway
PORT=5000
WEBHOOK_BASE_URL=https://dit-domæne.railway.app
